  "source": "MOD = 998244353\ndef comb(n, r):\n    nu = 1\n    de = 1\n    for i in range(r):\n        nu = nu * (n - i) % MOD\n        de = de * (i + 1) % MOD\n    return nu * pow(de, -1, MOD) % MOD\n\n\nN, K = map(int, input().split())\nA = list(map(int, input().split()))\n\nA.sort()\nans = 0\nfor i in range(K - 1, N):\n    ans = (ans + A[i] * comb(i, i - K + 1)) % MOD\n\nprint(ans)\n"
