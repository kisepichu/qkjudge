# compose 用の環境変数テンプレート。`cp .env.example .env` して値を埋める。
# .env は gitignore 対象 (secret を含めるため絶対にコミットしない)。

# --- DB (mariadb サービス) ---
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=qkjudge
MARIADB_USER=qkjudge
MARIADB_PASSWORD=change-me

# --- アプリ ---
# CORS: Allow-Credentials 併用のため単一オリジンのみ (ワイルドカード不可)。手元フロントの URL。
CORS_ALLOW_ORIGIN=http://localhost:3000
# cookie 署名鍵: 64 hex (32 byte)。`openssl rand -hex 32` で生成。
# 未設定なら起動毎にランダム生成され、再起動で全員ログアウトする。
SESSION_KEY=
# GitHub webhook (problems 自動 fetch) の署名検証トークン。
GITHUB_WEBHOOK_TOKEN=change-me-webhook
# JDoodle (Compiler API) 資格情報。
COMPILER_API_CLIENT_ID=
COMPILER_API_CLIENT_SECRET=
